# Verifies that ver_ge compares version components numerically, so 1.2.9 is
# correctly treated as lower than 1.2.10.
#
# File not following:
#  shellcheck disable=SC1090,SC1091
. "$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd -P)"/../lib/base.sh
ver_ge 1.2.9 1.2.10 || die 1.2.9
