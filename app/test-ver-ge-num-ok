#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# Verifies that ver_ge compares version components numerically rather than
# lexically, so double-digit components like 10 correctly outrank
# single-digit ones like 9.
#
# File not following:
#  shellcheck disable=SC1090,SC1091
. "$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd -P)"/../lib/base.sh
for v in 1.2.10 1.10.0 10.0.0; do
	ver_ge "$v" 1.2.9 || die "$v"
done
