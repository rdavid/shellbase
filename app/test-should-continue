# Manually verifies should_continue's interactive prompt, using both the
# default message and a custom one. Excluded from the automated test.do loop
# since it needs real terminal input.
#
# File not following:
#  shellcheck disable=SC1090,SC1091
. "$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd -P)"/../lib/base.sh
should_continue || cya Stopped first.
log Continued first.
should_continue You\'re "$USER", continue || cya Stopped second.
log Continued second.
