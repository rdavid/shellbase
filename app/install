#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2022-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# Installs lib/base.sh into /usr/local/bin. Compares the new version
# against an installed one and asks for confirmation before copying.
#
# File not following, variable appears unused, and uses local variables:
#  shellcheck disable=SC1090,SC2034,SC2039,SC3043
set -- "$@" --quiet
BSH="$(
	CDPATH='' cd -- "$(dirname -- "$0" 2>&1)" 2>&1 && pwd -P 2>&1
)"/../lib/base.sh || {
	err=$?
	printf >&2 %s\\n "$BSH"
	exit "$err"
}
readonly \
	BASE_APP_VERSION=0.9.20260720 \
	BASE_MIN_VERSION=0.9.20260707 \
	BSH \
	DST=/usr/local/bin \
	TGT=/usr/local/bin/base.sh
. "$BSH"

# Validates and installs.
main() {
	validate
	process
}

# Compares the new version against an installed one, asks for confirmation,
# and copies base.sh to the destination. The version string contains the
# program name and version, for example shellbase 0.9.20260718.
process() {
	local msg new old
	new="$(sh "$BSH" --quiet --version 2>&1)" || die "$new"
	file_exists "$TGT" || {
		cmd_run cp "$BSH" "$TGT"
		printf '%s is installed in %s.\n' "$new" "$DST"
		return
	}
	old="$(sh "$TGT" --quiet --version 2>&1)" || {
		logw "$old". Continuing with an unreadable version.
		old='An unreadable version'
	}
	[ "$old" = "$new" ] &&
		msg="$new is already installed in $DST. Continue anyway" ||
		msg="$old is installed in $DST. Update to $new"
	should_continue "$msg" || cya
	cmd_run cp -f "$BSH" "$TGT"
	printf '%s is updated to %s in %s.\n' "$old" "$new" "$DST"
}

# Verifies that the destination directory exists.
validate() {
	file_exists "$DST" || die "$DST": No such directory.
}

# Entry point.
main "$@"
