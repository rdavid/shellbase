#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2023-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# Updates README.adoc with current links to the public functions. By default
# does not update the file and works as a linter.
#
# File not following, variable appears unused, and uses local variables:
#  shellcheck disable=SC1090,SC2034,SC2039,SC3043
BSH="$(
	CDPATH='' cd -- "$(dirname -- "$0" 2>&1)" 2>&1 && pwd -P 2>&1
)"/../lib/base.sh || {
	err=$?
	printf >&2 %s\\n "$BSH"
	exit "$err"
}
BASE_APP_USAGE="$(
	cat <<-EOM 2>&1
		  -a, --action      Replaces README with updated version.
	EOM
)" || {
	err=$?
	printf >&2 %s\\n "$BASE_APP_USAGE"
	exit "$err"
}
readonly \
	BASE_APP_USAGE \
	BASE_APP_VERSION=0.9.20260720 \
	BASE_MIN_VERSION=0.9.20260718 \
	BSH \
	TGT=README.adoc
set -- "$@" --quiet
. "$BSH"
readonly \
	BEG="$BASE_WIP"/beg \
	END="$BASE_WIP"/end \
	MID="$BASE_WIP"/mid \
	OUT="$BASE_WIP"/out

# Parses arguments, validates the environment, analyzes the source, and updates.
main() {
	parse "$@"
	validate
	analyze
	update
}

# Parses base.sh for functions and re-creates the README. Uses GNU grep with
# the PCRE option.
analyze() {
	local num
	num="$(awk '/The public functions are/ {print FNR}' "$TGT" 2>&1)" ||
		die "$num"
	head -n "$num" "$TGT" >"$BEG"
	grep --line-number --perl-regexp '^(?!base)\w.*{$' "$BSH" |
		rev |
		cut -c5- |
		rev |
		awk -F: '{print "{url-base}#L"$1"[`"$2"`],"}' |
		sed '$s/\,/./g' >"$MID"
	num="$(awk '/Global variables/ {print FNR}' "$TGT" 2>&1)" ||
		die "$num"
	num=$((num - 1))
	tail -n +"$num" "$TGT" >"$END"
	cat "$BEG" "$MID" "$END" >"$OUT"
}

# Parses command line arguments.
parse() {
	local arg
	for arg; do
		shift
		case "$arg" in
		-a | --action) ACT=true ;;
		esac
	done
	var_exists ACT || ACT=false
	readonly ACT
}

# Compares the new README against the current one. Updates if needed. cmp
# takes only the short -s flag. POSIX defines no long form.
update() {
	cmd_run cmp -s "$OUT" "$TGT" && cya "$TGT" is updated.
	[ "$ACT" = false ] && die "$TGT" should be updated.
	iswritable "$TGT" || die
	cmd_run cp -f "$OUT" "$TGT"
	log "$TGT" has been updated.
}

# Checks the environment. The colon resets the failed GNU grep probe's
# status, so cya leaves gracefully with 0.
validate() {
	isreadable "$BSH" "$TGT" || die
	cmd_run grep --help && return
	:
	cya GNU grep is required.
}

# Entry point.
main "$@"
