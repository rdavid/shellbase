FROM ghcr.io/rdavid/goredoer:0.9.20260707 as goredoer
FROM alpine:3.24.1
LABEL maintainer=David\ Rabkin\ <david@rabkin.co.il>
ENV \
	TIME_ZONE=Asia/Jerusalem \
	USER=shellbase
COPY LICENSES/* /licenses/
WORKDIR /bin
COPY --from=goredoer /goredo .
RUN \
	apk add --no-cache --update \
		bash~=5.3 \
		coreutils~=9.11 \
		curl~=8.21 \
		dash~=0.5 \
		fish~=4.6 \
		grep~=3.12 \
		loksh~=7.9 \
		oksh~=7.8 \
		perl-utils~=5.42 \
		shellcheck~=0.11 \
		shfmt~=3.13 \
		tcsh~=6.24 \
		typos~=1.47 \
		tzdata~=2026 \
		util-linux~=2 \
		vale-doc~=3.13 \
		yamllint~=1.38 \
		yash~=2.60 \
		zsh~=5.9 \
	&& rm -rf /var/cache/apk/* \
	&& adduser -D -u 1001 "$USER" "$USER" \
	&& cp /usr/share/zoneinfo/"$TIME_ZONE" /etc/localtime \
	&& printf %s "$TIME_ZONE" > /etc/timezone \
	&& goredo -symlinks
USER "$USER"
WORKDIR /home/"$USER"
COPY \
	--chown="$USER":"$USER" \
	. .
ENTRYPOINT [ "redo", "-j=10" ]
