FROM ghcr.io/rdavid/goredoer:0.9.20260404 as goredoer
FROM registry.access.redhat.com/ubi9/ubi-minimal:9.8-1782191395
LABEL maintainer=David\ Rabkin\ <david@rabkin.co.il>
ENV \
	CM_BIN=/usr/local/bin/checkmake \
	CM_URL=https://github.com/mrtazz/checkmake/releases/download/v0.3.2/checkmake-v0.3.2.linux.amd64 \
	HL_BIN=/usr/local/bin/hadolint \
	HL_URL=https://github.com/hadolint/hadolint/releases/download/v2.14.0/hadolint-linux-x86_64 \
	TZ=Asia/Jerusalem \
	USER=shellbase
COPY LICENSES/* /licenses/
WORKDIR /bin
COPY --from=goredoer /goredo .
RUN \
	microdnf update --assumeyes --disableplugin=subscription-manager \
	&& rm --force --recursive /var/cache/yum \
	&& microdnf install --assumeyes --disableplugin=subscription-manager \
		bash-5.1.8 \
		diffutils-3.7 \
		findutils-4.8.0 \
		perl-Digest-SHA-6.02 \
		procps-ng-3.3.17 \
		tzdata-2026b \
		util-linux-2.37.4 \
	&& microdnf clean all --disableplugin=subscription-manager \
	&& useradd --create-home "$USER" \
	&& curl \
		--continue-at - \
		--location \
		--output "$CM_BIN" \
		--retry 10 \
		--retry-all-errors \
		--silent \
		"$CM_URL" \
	&& curl \
		--continue-at - \
		--location \
		--output "$HL_BIN" \
		--retry 10 \
		--retry-all-errors \
		--silent \
		"$HL_URL" \
	&& chmod +x "$CM_BIN" "$HL_BIN" \
	&& goredo -symlinks
USER "$USER"
WORKDIR /home/"$USER"
COPY \
	--chown="$USER":"$USER" \
	. .
ENTRYPOINT [ "redo", "-j=10" ]
